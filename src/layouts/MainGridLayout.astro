  #right-sidebar {
    transition: opacity 0.35s ease-in-out,
                transform 0.35s ease-in-out;
  }


  @keyframes swupFadeOut {
    from {
      opacity: 1;
    }
    to {
      opacity: 0.95;
    }
  }

  :root {
    --banner-title-text-shadow: 0 4px 24px rgba(0, 0, 0, 0.6);
    --banner-subtitle-text-shadow: 0 2px 16px rgba(0, 0, 0, 0.6);
  }

  /* 横幅文字阴影由外层 overlay 统一控制动画，避免刷新时子元素动画抢渲染层 */
