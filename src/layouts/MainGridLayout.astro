    animation: none !important;
    text-shadow: var(--banner-title-text-shadow) !important;
  }

  .banner-text-overlay .banner-subtitle {
    animation: none !important;
    text-shadow: var(--banner-subtitle-text-shadow) !important;
  }

  .banner-text-overlay {
    opacity: 0;
    transform: none;
    transition: opacity 200ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    box-sizing: border-box;
  }

  .banner-text-overlay.is-visible {
    opacity: 1;
    transform: none;
  }

  .banner-page-overlay {
    opacity: 0;
    transform: none;
    transition: opacity 200ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    padding-top: calc(var(--banner-height-extend, 0px) * 0.00);
    box-sizing: border-box;
  }

  .banner-page-overlay.is-visible {
    opacity: 1;
    transform: none;
  }

  .banner-page-overlay-title {
    text-shadow: var(--banner-title-text-shadow) !important;
  }

  .banner-page-overlay-meta {
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.75);
  }

  html.is-leaving .banner-page-overlay.is-visible {
    transition: opacity 200ms cubic-bezier(0.55, 0.055, 0.675, 0.19);
    opacity: 0;
    transform: none;
  }

  html.is-leaving .banner-text-overlay.is-visible {
    transition: opacity 200ms cubic-bezier(0.55, 0.055, 0.675, 0.19);
    opacity: 0;
    transform: none;
  }

  html.keep-home-banner-overlay.is-leaving .banner-text-overlay.is-visible {
    display: flex !important;
    opacity: 1;
    transform: none;
  }

  html.keep-home-banner-overlay .banner-text-overlay {
    display: flex !important;
    opacity: 1 !important;
    transform: none !important;
  }

  @media (max-width: 1023px) {
    .banner-page-overlay-content {
      width: 92%;
      margin-top: 0;
    }
  }
</style>

