<script>
const TARGET_IMAGE_SELECTOR = "img.md3-responsive-image, img.ff-theme-responsive-image";
const IMAGE_LOADER_HEIGHT = 4;
const PAGE_LOADER_PROGRESS_DURATION = 6000;
const PAGE_LOADER_FINISH_DURATION = 420;
const PAGE_LOADER_MIN_ACTIVE_MS = 260;

type WindowWithResponsiveLoader = Window & {
	__fireflyResponsiveImageLoaderInit__?: boolean;
	__fireflyResponsiveImageLoaderSwupHooksBound__?: boolean;
	swup?: {
		hooks?: {
			on: (eventName: string, callback: (...args: any[]) => void) => void;
		};
	};
};

let pageLoadingCount = 0;
let pageLoadingFallbackTimer: number | undefined;
let pageLoaderProgressRaf: number | undefined;
let pageLoaderFinishTimer: number | undefined;
let pageLoaderDeferredFinishTimer: number | undefined;
let pageLoaderStartedAt = 0;
let lastPageLoadingKey = "";
let lastPageLoadingAt = 0;
let hasSwupLifecycle = false;

function getOrCreatePageLoader() {
	let host = document.querySelector<HTMLDivElement>('[data-ff-md3-page-loader-root="true"]');
	if (!host) {
		host = document.createElement("div");
		host.dataset.ffMd3PageLoaderRoot = "true";
		host.className = "ff-md3-page-loader-root";
		host.setAttribute("aria-hidden", "true");
		document.documentElement.append(host);
	}

	let loader = document.querySelector<HTMLDivElement>('[data-ff-md3-page-loader="true"]');
	if (loader) {
		return loader;
	}

	loader = document.createElement("div");
	loader.dataset.ffMd3PageLoader = "true";
	loader.className = "ff-md3-page-loader";
	loader.setAttribute("aria-hidden", "true");
	loader.innerHTML = '<span class="ff-md3-page-loader-bar"></span>';
	host.append(loader);
	return loader;
}

function syncPageLoaderState() {
	const loader = getOrCreatePageLoader();
	if (pageLoadingCount > 0) {
		loader.classList.add("ff-md3-page-loader--active");
	} else {
		loader.classList.remove("ff-md3-page-loader--active");
	}
}

function startPageLoaderAnimation() {
	const loader = getOrCreatePageLoader();
	const bar = loader.querySelector<HTMLSpanElement>(".ff-md3-page-loader-bar");
	if (!bar) {
		return;
	}

	if (pageLoaderProgressRaf) {
		window.cancelAnimationFrame(pageLoaderProgressRaf);
		pageLoaderProgressRaf = undefined;
	}
	if (pageLoaderFinishTimer) {
		window.clearTimeout(pageLoaderFinishTimer);
		pageLoaderFinishTimer = undefined;
	}
	if (pageLoaderDeferredFinishTimer) {
		window.clearTimeout(pageLoaderDeferredFinishTimer);
		pageLoaderDeferredFinishTimer = undefined;
	}

	loader.classList.add("ff-md3-page-loader--active");
	pageLoaderStartedAt = Date.now();
	bar.style.transition = "none";
	bar.style.transform = "scaleX(0)";
	bar.style.opacity = "1";
	bar.getBoundingClientRect();

	pageLoaderProgressRaf = window.requestAnimationFrame(() => {
		bar.style.transition = `transform ${PAGE_LOADER_PROGRESS_DURATION}ms cubic-bezier(0.2, 0, 0, 1)`;
		bar.style.transform = "scaleX(0.92)";
		pageLoaderProgressRaf = undefined;
	});
}

function finishPageLoaderAnimation() {
	const elapsed = pageLoaderStartedAt ? Date.now() - pageLoaderStartedAt : PAGE_LOADER_MIN_ACTIVE_MS;
	if (elapsed < PAGE_LOADER_MIN_ACTIVE_MS) {
		if (pageLoaderDeferredFinishTimer) {
			window.clearTimeout(pageLoaderDeferredFinishTimer);
		}
		pageLoaderDeferredFinishTimer = window.setTimeout(() => {
			pageLoaderDeferredFinishTimer = undefined;
			finishPageLoaderAnimation();
		}, PAGE_LOADER_MIN_ACTIVE_MS - elapsed);
		return;
	}

	const loader = getOrCreatePageLoader();
	const bar = loader.querySelector<HTMLSpanElement>(".ff-md3-page-loader-bar");
	if (!bar) {
		return;
	}

	if (pageLoaderProgressRaf) {
		window.cancelAnimationFrame(pageLoaderProgressRaf);
		pageLoaderProgressRaf = undefined;
	}
	if (pageLoaderFinishTimer) {
		window.clearTimeout(pageLoaderFinishTimer);
		pageLoaderFinishTimer = undefined;
	}
	if (pageLoaderDeferredFinishTimer) {
		window.clearTimeout(pageLoaderDeferredFinishTimer);
		pageLoaderDeferredFinishTimer = undefined;
	}

	loader.classList.add("ff-md3-page-loader--active");
	bar.style.transition = `transform ${PAGE_LOADER_FINISH_DURATION}ms cubic-bezier(0.22, 0.61, 0.36, 1), opacity ${PAGE_LOADER_FINISH_DURATION}ms linear`;
	bar.style.transform = "scaleX(1)";
	bar.style.opacity = "0.88";

	pageLoaderFinishTimer = window.setTimeout(() => {
		loader.classList.remove("ff-md3-page-loader--active");
		bar.style.transition = "none";
		bar.style.transform = "scaleX(0)";
		bar.style.opacity = "1";
		pageLoaderStartedAt = 0;
		pageLoaderFinishTimer = undefined;
	}, PAGE_LOADER_FINISH_DURATION + 40);
}

function startPageLoading() {
	const wasIdle = pageLoadingCount === 0;
	pageLoadingCount += 1;
	if (wasIdle) {
		startPageLoaderAnimation();
	} else {
		syncPageLoaderState();
	}

	if (pageLoadingFallbackTimer) {
		window.clearTimeout(pageLoadingFallbackTimer);
	}
	pageLoadingFallbackTimer = window.setTimeout(() => {
		pageLoadingCount = 0;
		finishPageLoaderAnimation();
	}, 12000);
}

function tryStartPageLoadingByUrl(next: string | URL) {
	let nextUrl: URL;
	try {
		nextUrl =
			next instanceof URL ? next : new URL(next, window.location.href);
	} catch {
		return;
	}

	if (nextUrl.origin !== window.location.origin) {
		return;
	}

	const currentUrl = new URL(window.location.href);
	if (
		nextUrl.pathname === currentUrl.pathname &&
		nextUrl.search === currentUrl.search &&
		nextUrl.hash
	) {
		return;
	}

	const nextKey = `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`;
	const now = Date.now();
	if (nextKey === lastPageLoadingKey && now - lastPageLoadingAt < 400) {
		return;
	}
	lastPageLoadingKey = nextKey;
	lastPageLoadingAt = now;
	startPageLoading();
}

function stopPageLoading(force = false) {
	const prev = pageLoadingCount;
	if (force) {
		pageLoadingCount = 0;
	} else {
		pageLoadingCount = Math.max(0, pageLoadingCount - 1);
	}
	if (prev > 0 && pageLoadingCount === 0) {
		finishPageLoaderAnimation();
	} else {
		syncPageLoaderState();
	}

	if (pageLoadingCount === 0 && pageLoadingFallbackTimer) {
		window.clearTimeout(pageLoadingFallbackTimer);
		pageLoadingFallbackTimer = undefined;
	}
}

function setupPageLoaderTrigger() {
	getOrCreatePageLoader();

	document.addEventListener("click", (event) => {
		if (hasSwupLifecycle) {
			return;
		}
		if (
			event instanceof MouseEvent &&
			(event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey)
		) {
			return;
		}

		const target = event.target as Element | null;
		const anchor = target?.closest?.("a[href]") as HTMLAnchorElement | null;
		if (!anchor) {
			return;
		}

		if (anchor.target && anchor.target !== "_self") {
			return;
		}
		if (anchor.hasAttribute("download")) {
			return;
		}

		const href = anchor.getAttribute("href") || "";
		if (!href || href.startsWith("#") || href.startsWith("javascript:")) {
			return;
		}

		let nextUrl: URL;
		try {
			nextUrl = new URL(anchor.href, window.location.href);
		} catch {
			return;
		}
		tryStartPageLoadingByUrl(nextUrl);
	});
}

function setupSwupPageLoaderTrigger() {
	const win = window as WindowWithResponsiveLoader;
	if (win.__fireflyResponsiveImageLoaderSwupHooksBound__) {
		return;
	}

	const bindSwupHooks = () => {
		const swupHooks = win.swup?.hooks;
		if (!swupHooks) {
			return false;
		}

		hasSwupLifecycle = true;

		swupHooks.on("visit:start", (visit: { to?: { url?: string } }) => {
			const nextUrl = visit?.to?.url;
			if (nextUrl) {
				tryStartPageLoadingByUrl(nextUrl);
			} else {
				startPageLoading();
			}
		});
		swupHooks.on("visit:end", () => {
			stopPageLoading(true);
		});
		swupHooks.on("animation:skip", () => {
			stopPageLoading(true);
		});

		win.__fireflyResponsiveImageLoaderSwupHooksBound__ = true;
		return true;
	};

	if (bindSwupHooks()) {
		return;
	}

	document.addEventListener(
		"swup:enable",
		() => {
			bindSwupHooks();
		},
		{ once: true },
	);

	document.addEventListener("swup:visit:start", (event) => {
		hasSwupLifecycle = true;
		const custom = event as CustomEvent<{ to?: { url?: string } }>;
		const nextUrl = custom?.detail?.to?.url;
		if (nextUrl) {
			tryStartPageLoadingByUrl(nextUrl);
		} else {
			startPageLoading();
		}
	});
}

function ensureLoaderHost(parent: HTMLElement) {
	if (window.getComputedStyle(parent).position === "static") {
		parent.classList.add("ff-md3-loader-host");
	}
}

function getOrCreateLoader(img: HTMLImageElement) {
	const parent = img.parentElement as HTMLElement | null;
	if (!parent) {
		return null;
	}

	if (!img.dataset.ffMd3LoaderId) {
		img.dataset.ffMd3LoaderId = `ff-md3-loader-${Math.random().toString(36).slice(2, 10)}`;
	}

	let loader = parent.querySelector<HTMLSpanElement>(
		`:scope > span[data-ff-md3-loader-for="${img.dataset.ffMd3LoaderId}"]`,
	);
	if (loader) {
		return loader;
	}

	ensureLoaderHost(parent);
	loader = document.createElement("span");
	loader.className = "ff-md3-image-loader";
	loader.dataset.ffMd3LoaderFor = img.dataset.ffMd3LoaderId;
	loader.setAttribute("aria-hidden", "true");
	loader.innerHTML = '<span class="ff-md3-loader-indicator"></span>';
	parent.append(loader);
	return loader;
}

function syncLoaderPosition(img: HTMLImageElement) {
	const parent = img.parentElement as HTMLElement | null;
	if (!parent || !img.dataset.ffMd3LoaderId) {
		return;
	}

	const loader = parent.querySelector<HTMLSpanElement>(
		`:scope > span[data-ff-md3-loader-for="${img.dataset.ffMd3LoaderId}"]`,
	);
	if (!loader) {
		return;
	}

	const imageWidth = img.offsetWidth;
	const imageHeight = img.offsetHeight;
	const parentWidth = parent.clientWidth;
	const parentHeight = parent.clientHeight;

	const baseWidth = imageWidth > 0 ? imageWidth : parentWidth;
	const baseHeight = imageHeight > 0 ? imageHeight : parentHeight;
	const baseLeft = imageWidth > 0 ? img.offsetLeft : 0;
	const baseTop = imageHeight > 0 ? img.offsetTop : 0;
	const horizontalGap = Math.max(12, Math.min(24, Math.round(baseWidth * 0.08)));
	const width = baseWidth - horizontalGap * 2;
	const left = baseLeft + horizontalGap;
	const top = baseTop + Math.max(0, baseHeight / 2 - IMAGE_LOADER_HEIGHT / 2);

	if (width <= 40) {
		return;
	}

	loader.style.left = `${left}px`;
	loader.style.top = `${top}px`;
	loader.style.width = `${width}px`;
}

function hideLoader(img: HTMLImageElement) {
	const parent = img.parentElement as HTMLElement | null;
	if (!parent || !img.dataset.ffMd3LoaderId) {
		return;
	}

	const loader = parent.querySelector<HTMLSpanElement>(
		`:scope > span[data-ff-md3-loader-for="${img.dataset.ffMd3LoaderId}"]`,
	);
	if (!loader) {
		return;
	}

	loader.classList.remove("ff-md3-image-loader--active");
	window.setTimeout(() => loader.remove(), 220);
}

function markImagePending(img: HTMLImageElement) {
	img.classList.add("ff-md3-image-fade");
	img.classList.remove("ff-md3-image-fade--ready");
	img.classList.add("ff-md3-image-fade--pending");
}

function markImageReady(img: HTMLImageElement) {
	img.classList.add("ff-md3-image-fade");
	img.classList.remove("ff-md3-image-fade--pending");
	img.classList.add("ff-md3-image-fade--ready");
}

function bindImageLoader(img: HTMLImageElement) {
	if (img.complete && img.naturalWidth > 0) {
		markImageReady(img);
	} else {
		markImagePending(img);
	}

	if (img.dataset.ffMd3LoaderBound === "true") {
		const parent = img.parentElement as HTMLElement | null;
		if (parent && img.dataset.ffMd3LoaderId) {
			const loader = parent.querySelector<HTMLSpanElement>(
				`:scope > span[data-ff-md3-loader-for="${img.dataset.ffMd3LoaderId}"]`,
			);
			if (loader && !(img.complete && img.naturalWidth > 0)) {
				loader.classList.add("ff-md3-image-loader--active");
				markImagePending(img);
			}
		}
		if (img.complete && img.naturalWidth > 0) {
			markImageReady(img);
		}
		syncLoaderPosition(img);
		return;
	}

	img.dataset.ffMd3LoaderBound = "true";
	const loader = getOrCreateLoader(img);
	if (!loader) {
		return;
	}

	const onDone = () => {
		hideLoader(img);
		markImageReady(img);
		img.removeEventListener("load", onDone);
		img.removeEventListener("error", onDone);
	};

	img.addEventListener("load", onDone);
	img.addEventListener("error", onDone);

	if (img.complete && img.naturalWidth > 0) {
		hideLoader(img);
		markImageReady(img);
	} else {
		loader.classList.add("ff-md3-image-loader--active");
		markImagePending(img);
		syncLoaderPosition(img);
	}
}

function initResponsiveImageLoader(root: ParentNode = document) {
	root.querySelectorAll<HTMLImageElement>(TARGET_IMAGE_SELECTOR).forEach(bindImageLoader);
}

function syncAllLoaderPositions() {
	document.querySelectorAll<HTMLImageElement>(TARGET_IMAGE_SELECTOR).forEach(syncLoaderPosition);
}

function createDynamicObserver() {
	const observer = new MutationObserver((mutations) => {
		mutations.forEach((mutation) => {
			mutation.addedNodes.forEach((node) => {
				if (!(node instanceof HTMLElement)) {
					return;
				}

				if (node.matches(TARGET_IMAGE_SELECTOR)) {
					bindImageLoader(node as HTMLImageElement);
				}

				initResponsiveImageLoader(node);
				requestAnimationFrame(syncAllLoaderPositions);
			});
		});
	});

	observer.observe(document.body, { childList: true, subtree: true });
}

function setupResponsiveImageLoader() {
	const win = window as WindowWithResponsiveLoader;
	if (win.__fireflyResponsiveImageLoaderInit__) {
		initResponsiveImageLoader();
		requestAnimationFrame(syncAllLoaderPositions);
		return;
	}

	setupPageLoaderTrigger();
	setupSwupPageLoaderTrigger();

	document.addEventListener("astro:page-load", () => {
		initResponsiveImageLoader();
		requestAnimationFrame(syncAllLoaderPositions);
		stopPageLoading(true);
	});
	document.addEventListener("swup:content:replace", () => {
		initResponsiveImageLoader();
		requestAnimationFrame(syncAllLoaderPositions);
	});
	document.addEventListener("swup:contentReplaced", () => {
		initResponsiveImageLoader();
		requestAnimationFrame(syncAllLoaderPositions);
		stopPageLoading(true);
	});
	document.addEventListener("swup:visit:end", () => {
		stopPageLoading(true);
	});
	window.addEventListener("pageshow", () => {
		stopPageLoading(true);
	});
	window.addEventListener("resize", () => {
		requestAnimationFrame(syncAllLoaderPositions);
	});

	createDynamicObserver();
	win.__fireflyResponsiveImageLoaderInit__ = true;
	initResponsiveImageLoader();
	requestAnimationFrame(syncAllLoaderPositions);
}

if (document.readyState === "loading") {
	document.addEventListener("DOMContentLoaded", setupResponsiveImageLoader, { once: true });
} else {
	setupResponsiveImageLoader();
}
</script>

<style is:global>
:root {
	--ff-md3-loader-track: color-mix(in oklch, var(--primary) 24%, transparent 76%);
	--ff-md3-loader-indicator-start: color-mix(in oklch, var(--primary) 60%, white 40%);
	--ff-md3-loader-indicator-end: color-mix(in oklch, var(--primary) 90%, white 10%);
}

:root.dark {
	--ff-md3-loader-track: color-mix(in oklch, var(--primary) 38%, transparent 62%);
	--ff-md3-loader-indicator-start: color-mix(in oklch, var(--primary) 68%, white 32%);
	--ff-md3-loader-indicator-end: color-mix(in oklch, var(--primary) 88%, white 12%);
}

.ff-md3-loader-host {
	position: relative;
}

img.md3-responsive-image:not(.ff-md3-image-fade--ready),
img.ff-theme-responsive-image:not(.ff-md3-image-fade--ready) {
	opacity: 0;
}

.ff-md3-image-fade {
	transition:
		opacity 280ms cubic-bezier(0.2, 0, 0, 1),
		filter 320ms cubic-bezier(0.2, 0, 0, 1);
	will-change: opacity, filter;
}

.ff-md3-image-fade--pending {
	opacity: 0;
	filter: none;
}

.ff-md3-image-fade--ready {
	opacity: 1;
	filter: none;
}

.ff-md3-image-loader {
	position: absolute;
	height: 4px;
	border-radius: 999px;
	background: var(--ff-md3-loader-track);
	overflow: hidden;
	opacity: 0;
	pointer-events: none;
	transition: opacity 180ms cubic-bezier(0.2, 0, 0, 1);
	z-index: 6;
}

.ff-md3-image-loader--active {
	opacity: 1;
}

.ff-md3-loader-indicator {
	position: absolute;
	inset: 0 auto 0 0;
	width: 58%;
	transform-origin: left center;
	border-radius: 999px;
	background: linear-gradient(
		90deg,
		var(--ff-md3-loader-indicator-start) 0%,
		var(--ff-md3-loader-indicator-end) 100%
	);
	animation: ff-md3-loader-primary 1.75s cubic-bezier(0.2, 0, 0, 1) infinite;
}

.ff-md3-page-loader-root {
	position: fixed;
	inset: 0;
	pointer-events: none;
	z-index: 2147483647;
	isolation: isolate;
}

.ff-md3-page-loader {
	position: absolute;
	inset: 0 0 auto 0;
	height: 4px;
	background: transparent;
	opacity: 0;
	overflow: hidden;
	pointer-events: none;
	transition: opacity 180ms cubic-bezier(0.2, 0, 0, 1);
	z-index: 1;
}

.ff-md3-page-loader-bar {
	position: absolute;
	inset: 0;
	width: 100%;
	transform-origin: left center;
	transform: scaleX(0);
	border-radius: 999px;
	opacity: 1;
	will-change: transform;
	background: linear-gradient(
		90deg,
		var(--ff-md3-loader-indicator-start) 0%,
		var(--ff-md3-loader-indicator-end) 100%
	);
}

.ff-md3-page-loader--active {
	opacity: 1;
}

@keyframes ff-md3-loader-primary {
	0% {
		transform: translateX(-130%) scaleX(0.3);
	}
	45% {
		transform: translateX(8%) scaleX(0.95);
	}
	100% {
		transform: translateX(185%) scaleX(0.42);
	}
}

@media (prefers-reduced-motion: reduce) {
	.ff-md3-image-fade {
		transition: none;
	}

	.ff-md3-image-fade--pending {
		opacity: 0;
		filter: none;
	}

	.ff-md3-image-fade--ready {
		opacity: 1;
		filter: none;
	}

	.ff-md3-loader-indicator {
		animation: none;
		transform: translateX(0);
	}

	.ff-md3-page-loader-bar {
		transform: scaleX(0.56);
		opacity: 1;
	}
}
</style>
