---
import FloatingButton from "@/components/common/FloatingButton.astro";
---

<!-- There can't be a filter on parent element, or it will break `fixed` -->
<div id="back-to-top-wrapper" class="back-to-top-wrapper hide">
  <FloatingButton
    id="back-to-top-btn"
    icon="material-symbols:keyboard-arrow-up-rounded"
    ariaLabel="Back to Top"
    onclick="backToTop()"
    class=""
  />
  <!-- 圆形进度条 -->
  <svg class="progress-ring" viewBox="0 0 120 120">
    <circle cx="60" cy="60" r="40" class="progress-ring-bg"></circle>
    <circle
      cx="60"
      cy="60"
      r="40"
      class="progress-ring-circle"
      style="--progress: 0%"
    ></circle>
  </svg>
</div>

<script is:raw is:inline>
  var BACK_TO_TOP_VISIBLE_OFFSET = 200;

  function backToTop() {
    // 直接使用原生滚动，避免OverlayScrollbars冲突
    window.scroll({ top: 0, behavior: "smooth" });
  }

  function clampScrollPercent(value) {
    return Math.min(Math.max(value, 0), 100);
  }

  function getScrollTop() {
    return (
      window.pageYOffset ||
      document.documentElement.scrollTop ||
      document.body.scrollTop ||
      0
    );
  }

  function getViewportHeight() {
    return window.innerHeight || document.documentElement.clientHeight || 0;
  }

  function calculateDocumentScrollProgress() {
    const scrollTop = getScrollTop();
    const docHeight = document.documentElement.scrollHeight - getViewportHeight();
    const scrollPercent = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    return clampScrollPercent(scrollPercent);
  }

  function isHomePagePath() {
    const pathname = window.location.pathname.replace(/\/+$/, "");
    return pathname === "";
  }

  function getContentProgressTarget() {
    if (isHomePagePath()) return null;

    return (
      document.querySelector("[data-scroll-progress-target]") ||
      document.querySelector("#content-wrapper .custom-md") ||
      document.querySelector(".custom-md")
    );
  }

  function getElementTop(element) {
    return element.getBoundingClientRect().top + getScrollTop();
  }

  function getElementHeight(element) {
    return Math.max(
      element.scrollHeight || 0,
      element.getBoundingClientRect().height || 0,
      element.offsetHeight || 0
    );
  }

  function calculateContentScrollProgress(contentElement) {
    const scrollTop = getScrollTop();
    const viewportHeight = getViewportHeight();
    const contentTop = getElementTop(contentElement);
    const contentBottom = contentTop + getElementHeight(contentElement);
    const progressStart = Math.max(0, contentTop - viewportHeight);
    const progressEnd = Math.max(progressStart, contentBottom - viewportHeight);

    if (progressEnd <= progressStart) {
      return scrollTop >= progressStart ? 100 : 0;
    }

    return clampScrollPercent(
      ((scrollTop - progressStart) / (progressEnd - progressStart)) * 100
    );
  }

  function calculateScrollProgress() {
    const contentElement = getContentProgressTarget();
    if (!contentElement) return calculateDocumentScrollProgress();

    return calculateContentScrollProgress(contentElement);
  }

  // 响应式返回顶部按钮管理器
  window.BackToTopManager = class BackToTopManager {
    constructor() {
      this.wrapper = document.getElementById("back-to-top-wrapper");
      this.button = document.getElementById("back-to-top-btn");
      this.progressRing = this.wrapper?.querySelector(".progress-ring");
      this.progressRingCircle = this.wrapper?.querySelector(
        ".progress-ring-circle"
      );
      this.rafId = 0;
      this.handleViewportChange = this.handleViewportChange.bind(this);
      this.init();
    }

    init() {
      if (!this.button || !this.wrapper) return;

      window.addEventListener("scroll", this.handleViewportChange, {
        passive: true,
      });
      window.addEventListener("resize", this.handleViewportChange, {
        passive: true,
      });
      this.update();
    }

    destroy() {
      window.removeEventListener("scroll", this.handleViewportChange);
      window.removeEventListener("resize", this.handleViewportChange);
      if (this.rafId) {
        cancelAnimationFrame(this.rafId);
        this.rafId = 0;
      }
    }

    handleViewportChange() {
      if (this.rafId) cancelAnimationFrame(this.rafId);
      this.rafId = requestAnimationFrame(() => {
        this.rafId = 0;
        this.update();
      });
    }

    setVisible(isVisible) {
      this.wrapper.classList.toggle("hide", !isVisible);
      this.button.classList.toggle("hide", !isVisible);
      this.progressRing?.classList.toggle("hide", !isVisible);
    }

    update() {
      const scrollTop = getScrollTop();
      const scrollPercent = calculateScrollProgress();

      this.setVisible(scrollTop > BACK_TO_TOP_VISIBLE_OFFSET);

      // 更新进度条；底圈和进度圈由同一个 SVG 随 wrapper 一起显示/隐藏
      if (this.progressRingCircle) {
        this.progressRingCircle.style.setProperty(
          "--progress",
          `${scrollPercent}%`
        );
      }
    }
  };

  function initBackToTopManager() {
    if (window.fireflyBackToTopManager?.destroy) {
      window.fireflyBackToTopManager.destroy();
    }
    window.fireflyBackToTopManager = new window.BackToTopManager();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBackToTopManager, {
      once: true,
    });
  } else {
    initBackToTopManager();
  }

  if (!window.fireflyBackToTopPageLoadBound) {
    document.addEventListener("astro:page-load", initBackToTopManager);
    window.fireflyBackToTopPageLoadBound = true;
  }
</script>

<style is:global>
  #back-to-top-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    opacity: 1;
    pointer-events: auto;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #back-to-top-wrapper.hide {
    transform: scale(0.5);
    opacity: 0;
    pointer-events: none;
    height: 0 !important;
    width: 0 !important;
    margin: 0 !important;
    border-width: 0 !important;
    padding: 0 !important;
  }

  #back-to-top-wrapper #back-to-top-btn {
    width: 100%;
    height: 100%;
  }

  /* 圆形进度条样式 */
  .progress-ring {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .progress-ring.hide,
  #back-to-top-btn.hide + .progress-ring {
    opacity: 0;
  }

  .progress-ring-bg {
    fill: none;
    stroke: rgba(0, 0, 0, 0.08);
    stroke-width: 4;
  }

  .progress-ring-circle {
    fill: none;
    stroke: var(--primary);
    stroke-width: 4;
    stroke-linecap: round;
    stroke-dasharray: 251.33; /* 2 * π * 40 */
    stroke-dashoffset: calc(251.33 * (1 - var(--progress, 0%) / 100%));
    transition: stroke-dashoffset 0.3s ease;
    opacity: 0.8;
  }

  /* 暗色主题 */
  :global(.dark) .progress-ring-bg {
    stroke: rgba(255, 255, 255, 0.1);
  }

  :global(.dark) .progress-ring-circle {
    opacity: 0.9;
  }

  /* 响应式调整 */
  @media (max-width: 768px) {
    #back-to-top-wrapper {
      width: 3rem;
      height: 3rem;
    }

    .progress-ring-bg,
    .progress-ring-circle {
      stroke-width: 3;
    }
  }

  @media (max-width: 480px) {
    #back-to-top-wrapper {
      width: 2.5rem;
      height: 2.5rem;
    }

    .progress-ring-bg,
    .progress-ring-circle {
      stroke-width: 2.5;
    }
  }

  @media (max-width: 360px) {
    #back-to-top-wrapper {
      width: 2rem;
      height: 2rem;
    }

    .progress-ring-bg,
    .progress-ring-circle {
      stroke-width: 2;
    }
  }

  @media (max-width: 320px) {
    #back-to-top-wrapper {
      width: 1.75rem;
      height: 1.75rem;
    }

    .progress-ring-bg,
    .progress-ring-circle {
      stroke-width: 1.5;
    }
  }
</style>
