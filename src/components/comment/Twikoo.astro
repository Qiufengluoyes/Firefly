---
import { commentConfig } from "@/config/commentConfig";
import { icons as mdiIcons } from "@iconify-json/mdi";

interface Props {
	path: string;
}

const config = {
	...commentConfig.twikoo,
	el: "#tcomment",
	path: Astro.props.path,
};
const mdiChevronDownBody =
	mdiIcons.icons["chevron-down"]?.body ??
	'<path fill="currentColor" d="M7.41 8.58L12 13.17l4.59-4.59L18 10l-6 6l-6-6z"/>';
---

<div id="tcomment"></div>
<script
  src="https://s4.zstatic.net/npm/twikoo@1.7.9/dist/twikoo.min.js"
  integrity="sha384-uS5XTM0hprJZj0R184twNRV12L55VagOlT/XQaj1uAebA0RtO7diEr+dE9TBn5N2"
  crossorigin="anonymous"></script>
<script is:inline define:vars={{ config, mdiChevronDownBody }}>
  // 获取当前页面路径
  function getCurrentPath() {
    const pathname = window.location.pathname;
    return pathname.endsWith("/") && pathname.length > 1
      ? pathname.slice(0, -1)
      : pathname;
  }

  // 动态创建配置对象
  function createTwikooConfig() {
    return {
      ...config,
      path: getCurrentPath(),
      el: "#tcomment",
    };
  }

  const MARKDOWN_GUIDE_URL =
    "https://guides.github.com/features/mastering-markdown/";
  const MARKDOWN_TRIGGER_SELECTOR =
    "#tcomment .tk-row.actions .__markdown, #twikoo .tk-row.actions .__markdown";
  const MARKDOWN_POPOVER_SELECTOR = ".tk-markdown-guide-popover";
  const MARKDOWN_POPOVER_OPEN_CLASS = "is-open";
  const MARKDOWN_POPOVER_CLOSING_CLASS = "is-closing";
  const TWIKOO_EXPAND_SELECTOR =
    "#tcomment .tk-expand-wrap .tk-expand, #tcomment .tk-collapse-wrap .tk-expand, #twikoo .tk-expand-wrap .tk-expand, #twikoo .tk-collapse-wrap .tk-expand";

  function getClosestElement(target, selector) {
    return target instanceof Element ? target.closest(selector) : null;
  }

  function getMarkdownGuideUrl(trigger) {
    return (
      trigger.getAttribute("href") ||
      trigger.dataset.href ||
      MARKDOWN_GUIDE_URL
    );
  }

  function removeMarkdownGuidePopover(popover) {
    if (popover) popover.remove();
  }

  function closeMarkdownGuidePopover(immediate = false) {
    const popover = document.querySelector(MARKDOWN_POPOVER_SELECTOR);
    if (!popover) return;

    const trigger = window.fireflyTwikooMarkdownGuideTrigger;
    if (trigger) {
      trigger.setAttribute("aria-expanded", "false");
    }

    if (typeof window.fireflyTwikooMarkdownGuideCleanup === "function") {
      window.fireflyTwikooMarkdownGuideCleanup();
    }

    window.fireflyTwikooMarkdownGuideTrigger = null;
    window.fireflyTwikooMarkdownGuideCleanup = null;

    const shouldAnimate =
      !immediate &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!shouldAnimate) {
      removeMarkdownGuidePopover(popover);
      return;
    }

    popover.classList.remove(MARKDOWN_POPOVER_OPEN_CLASS);
    popover.classList.add(MARKDOWN_POPOVER_CLOSING_CLASS);

    const fallbackTimer = setTimeout(() => {
      removeMarkdownGuidePopover(popover);
    }, 260);

    popover.addEventListener(
      "transitionend",
      function (event) {
        if (event.target !== popover) return;
        clearTimeout(fallbackTimer);
        removeMarkdownGuidePopover(popover);
      },
      { once: true },
    );
  }

  function positionMarkdownGuidePopover(popover, trigger) {
    const triggerRect = trigger.getBoundingClientRect();
    const icon = trigger.querySelector("svg");
    const anchorRect = icon ? icon.getBoundingClientRect() : triggerRect;
    const anchorCenter = anchorRect.left + anchorRect.width / 2;
    const gap = 10;
    const margin = 8;
    const boundaryEl = trigger.closest(".twikoo") || document.getElementById("tcomment");
    const boundaryRect = boundaryEl
      ? boundaryEl.getBoundingClientRect()
      : { left: 0, right: window.innerWidth };
    const boundaryLeft = Math.max(margin, boundaryRect.left + margin);
    const boundaryRight = Math.min(window.innerWidth - margin, boundaryRect.right - margin);
    const offsetX =
      Number.parseFloat(
        getComputedStyle(document.documentElement).getPropertyValue(
          "--tk-markdown-popover-offset-x",
        ),
      ) || 0;
    const targetCenter = anchorCenter + offsetX;

    popover.style.visibility = "hidden";
    popover.style.left = "0px";
    popover.style.top = "0px";

    popover.style.width = "";
    const popoverRect = popover.getBoundingClientRect();
    const availableWidth = Math.max(0, boundaryRight - boundaryLeft);
    const centeredAvailableWidth =
      2 * Math.max(0, Math.min(targetCenter - boundaryLeft, boundaryRight - targetCenter));
    const maxCenteredWidth = Math.max(0, Math.min(availableWidth, centeredAvailableWidth));
    if (popoverRect.width > maxCenteredWidth) {
      popover.style.width = `${Math.floor(maxCenteredWidth)}px`;
    } else {
      popover.style.width = "";
    }

    const nextPopoverRect = popover.getBoundingClientRect();
    const popoverWidth = Math.min(nextPopoverRect.width, availableWidth);
    const left = targetCenter - popoverWidth / 2;

    let placement = "top";
    let top = triggerRect.top - nextPopoverRect.height - gap;
    if (top < margin) {
      placement = "bottom";
      top = triggerRect.bottom + gap;
    }

    const minArrowOffset = 14;
    const maxArrowOffset = popoverWidth - minArrowOffset;
    const arrowLeft = Math.max(
      minArrowOffset,
      Math.min(targetCenter - left, maxArrowOffset),
    );
    popover.dataset.placement = placement;
    popover.style.left = `${Math.round(left)}px`;
    popover.style.top = `${Math.round(top)}px`;
    popover.style.setProperty(
      "--tk-markdown-popover-arrow-left",
      `${Math.round(arrowLeft)}px`,
    );
    popover.style.visibility = "visible";
  }

  function showMarkdownGuidePopover(trigger) {
    const currentTrigger = window.fireflyTwikooMarkdownGuideTrigger;
    const existingPopover = document.querySelector(MARKDOWN_POPOVER_SELECTOR);
    if (existingPopover && currentTrigger === trigger) {
      closeMarkdownGuidePopover();
      return;
    }

    closeMarkdownGuidePopover(true);

    const guideUrl = getMarkdownGuideUrl(trigger);
    const popover = document.createElement("div");
    const surface = document.createElement("div");
    const urlText = document.createElement("span");
    const visitLink = document.createElement("a");
    const arrow = document.createElement("span");

    popover.className = "tk-markdown-guide-popover";
    popover.setAttribute("role", "dialog");
    popover.setAttribute("aria-label", "Markdown 帮助链接");
    surface.className = "tk-markdown-guide-surface";
    arrow.className = "tk-markdown-guide-arrow";
    arrow.setAttribute("aria-hidden", "true");

    urlText.className = "tk-markdown-guide-url";
    urlText.textContent = guideUrl;

    visitLink.className = "tk-markdown-guide-visit";
    visitLink.href = guideUrl;
    visitLink.target = "_blank";
    visitLink.rel = "noopener noreferrer";
    visitLink.textContent = "访问";

    surface.append(urlText, visitLink);
    popover.append(surface, arrow);
    document.body.append(popover);

    trigger.setAttribute("aria-haspopup", "dialog");
    trigger.setAttribute("aria-expanded", "true");
    window.fireflyTwikooMarkdownGuideTrigger = trigger;

    const updatePosition = () => positionMarkdownGuidePopover(popover, trigger);
    window.addEventListener("resize", updatePosition, { passive: true });
    window.addEventListener("scroll", updatePosition, {
      passive: true,
      capture: true,
    });
    window.fireflyTwikooMarkdownGuideCleanup = () => {
      window.removeEventListener("resize", updatePosition);
      window.removeEventListener("scroll", updatePosition, { capture: true });
    };

    requestAnimationFrame(() => {
      updatePosition();
      requestAnimationFrame(() => {
        popover.classList.add(MARKDOWN_POPOVER_OPEN_CLASS);
      });
    });
  }

  function bindMarkdownGuidePopover() {
    if (window.fireflyTwikooMarkdownGuideBound) return;
    window.fireflyTwikooMarkdownGuideBound = true;

    document.addEventListener(
      "click",
      function (event) {
        const visitLink = getClosestElement(
          event.target,
          ".tk-markdown-guide-visit",
        );
        if (visitLink) {
          setTimeout(closeMarkdownGuidePopover, 0);
          return;
        }

        const trigger = getClosestElement(
          event.target,
          MARKDOWN_TRIGGER_SELECTOR,
        );
        if (trigger) {
          event.preventDefault();
          event.stopPropagation();
          showMarkdownGuidePopover(trigger);
          return;
        }

        const popover = document.querySelector(MARKDOWN_POPOVER_SELECTOR);
        if (popover && !popover.contains(event.target)) {
          closeMarkdownGuidePopover();
        }
      },
      true,
    );

    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape") closeMarkdownGuidePopover();
    });
  }

  function moveTwikooAdminActions() {
    const adminActionGroups = document.querySelectorAll(
      "#tcomment .tk-comment .tk-meta > .tk-actions, #tcomment .tk-comment .tk-action > .tk-admin-actions, #tcomment .tk-comment .tk-admin-actions-line > .tk-admin-actions, #twikoo .tk-comment .tk-meta > .tk-actions, #twikoo .tk-comment .tk-action > .tk-admin-actions, #twikoo .tk-comment .tk-admin-actions-line > .tk-admin-actions",
    );

    adminActionGroups.forEach((adminActions) => {
      const main = adminActions.closest(".tk-main");
      const row = adminActions.closest(".tk-row");
      const actionPanel = row ? row.querySelector(".tk-action") : null;
      const extras = main
        ? Array.from(main.children).find((child) =>
            child.classList.contains("tk-extras"),
          )
        : null;
      let adminLine = main
        ? Array.from(main.children).find((child) =>
            child.classList.contains("tk-admin-actions-line"),
          )
        : null;
      if (main && !adminLine) {
        adminLine = document.createElement("div");
        adminLine.className = "tk-admin-actions-line";
        if (extras) {
          extras.after(adminLine);
        } else {
          main.append(adminLine);
        }
      }
      const target = adminLine || actionPanel;
      if (!target) return;

      adminActions.classList.add("tk-admin-actions");
      adminActions.setAttribute("aria-label", "评论管理操作");
      if (adminActions.parentElement !== target) {
        target.append(adminActions);
      }
    });
  }

  function syncTwikooExpandButtons() {
    const buttons = document.querySelectorAll(TWIKOO_EXPAND_SELECTOR);

    buttons.forEach((button) => {
      const firstIcon = Array.from(button.children).find((child) =>
        child.classList.contains("tk-expand-icon"),
      );
      const icon =
        firstIcon ||
        document.createElementNS("http://www.w3.org/2000/svg", "svg");

      if (!firstIcon) {
        icon.classList.add("tk-expand-icon");
        icon.setAttribute("aria-hidden", "true");
        icon.setAttribute("viewBox", "0 0 24 24");
        icon.setAttribute("focusable", "false");
        button.prepend(icon);
      }

      if (icon.dataset.icon !== "mdi:chevron-down") {
        icon.innerHTML = mdiChevronDownBody;
        icon.dataset.icon = "mdi:chevron-down";
      }

      button.classList.add("tk-expand-with-icon");
    });
  }

  function syncTwikooCommentLayout() {
    moveTwikooAdminActions();
    syncTwikooExpandButtons();
  }

  function bindTwikooAdminActionsLayout() {
    const commentEl = document.getElementById("tcomment");
    if (!commentEl) return;

    syncTwikooCommentLayout();

    if (window.fireflyTwikooAdminActionsObserver) {
      window.fireflyTwikooAdminActionsObserver.disconnect();
    }
    if (window.fireflyTwikooAdminActionsTimer) {
      window.clearInterval(window.fireflyTwikooAdminActionsTimer);
    }

    const observer = new MutationObserver(() => {
      requestAnimationFrame(syncTwikooCommentLayout);
    });
    observer.observe(commentEl, {
      childList: true,
      subtree: true,
    });
    window.fireflyTwikooAdminActionsObserver = observer;

    let syncCount = 0;
    window.fireflyTwikooAdminActionsTimer = window.setInterval(() => {
      syncTwikooCommentLayout();
      syncCount += 1;
      if (syncCount >= 20) {
        window.clearInterval(window.fireflyTwikooAdminActionsTimer);
        window.fireflyTwikooAdminActionsTimer = null;
      }
    }, 250);
  }

  function scheduleTwikooAdminActionsLayout() {
    requestAnimationFrame(syncTwikooCommentLayout);
    setTimeout(syncTwikooCommentLayout, 300);
    setTimeout(syncTwikooCommentLayout, 1000);
    setTimeout(syncTwikooCommentLayout, 2500);
  }

  // 初始化 Twikoo
  function initTwikoo() {
    if (typeof twikoo !== "undefined") {
      const commentEl = document.getElementById("tcomment");
      if (commentEl) {
        commentEl.innerHTML = "";

        const dynamicConfig = createTwikooConfig();
        console.log("[Twikoo] 初始化配置:", dynamicConfig);

        twikoo
          .init(dynamicConfig)
          .then(() => {
            console.log("[Twikoo] 初始化完成");
            bindMarkdownGuidePopover();
            bindTwikooAdminActionsLayout();
          })
          .catch((error) => {
            console.error("[Twikoo] 初始化失败:", error);
          });
      }
    } else {
      // 如果 Twikoo 未加载，稍后重试
      setTimeout(initTwikoo, 500);
    }
  }

  // 页面加载时初始化
  document.addEventListener("DOMContentLoaded", function () {
    initTwikoo();
    scheduleTwikooAdminActionsLayout();
  });

  // Swup 页面切换后重新初始化
  if (window.swup && window.swup.hooks) {
    window.swup.hooks.on("content:replace", function () {
      setTimeout(initTwikoo, 200);
      setTimeout(scheduleTwikooAdminActionsLayout, 500);
    });
  } else {
    document.addEventListener("swup:enable", function () {
      if (window.swup && window.swup.hooks) {
        window.swup.hooks.on("content:replace", function () {
          setTimeout(initTwikoo, 200);
          setTimeout(scheduleTwikooAdminActionsLayout, 500);
        });
      }
    });
  }

  // 自定义事件监听
  document.addEventListener("firefly:page:loaded", function () {
    const commentEl = document.getElementById("tcomment");
    if (commentEl) {
      console.log("[Twikoo] 通过自定义事件重新初始化");
      initTwikoo();
      scheduleTwikooAdminActionsLayout();
    }
  });
</script>
